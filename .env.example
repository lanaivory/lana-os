# From https://console.twilio.com/ — never commit real values
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=

# Cloud sync (Vercel KV / Upstash Redis REST) + passcode gate
# Create a KV store in the Vercel dashboard (Storage → Create → KV),
# then copy these connection vars (or run `vercel env pull`).
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_URL=
APP_PASSCODE=
